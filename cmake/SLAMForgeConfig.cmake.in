@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# FBOW does not provide a package config in common system installations.  The
# installed fallback modules keep the package usable in that case.
list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/modules")

find_dependency(Eigen3 3.3 NO_MODULE)
find_dependency(OpenCV 4.5 COMPONENTS core imgproc features2d calib3d videoio)

if(@SLAMFORGE_PACKAGE_WITH_SOPHUS@)
    # Prefer Sophus' own config package; use SLAMForge's fallback module only for
    # system installations that provide headers but no config file.
    find_package(Sophus CONFIG QUIET)
    if(NOT Sophus_FOUND)
        find_dependency(Sophus)
    endif()
endif()

if(@SLAMFORGE_PACKAGE_WITH_CERES@)
    find_dependency(Ceres CONFIG)
endif()

if(@SLAMFORGE_PACKAGE_WITH_G2O@)
    find_dependency(g2o CONFIG)
endif()

if(@SLAMFORGE_PACKAGE_WITH_FBOW@)
    find_dependency(FBOW)
endif()

if(@SLAMFORGE_PACKAGE_WITH_SPDLOG@)
    find_dependency(spdlog CONFIG)
endif()

if(@SLAMFORGE_PACKAGE_WITH_YAML@)
    find_dependency(yaml-cpp CONFIG)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/SLAMForgeTargets.cmake")
check_required_components(SLAMForge)
